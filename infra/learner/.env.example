# learner VM 個人服務環境變數（複製成 .env）
# 大多由 learner-setup.sh 依 metadata 自動產生；本檔為手動參考。

# --- 本機 LiteLLM（→ 自家專案 Vertex + 共用 TEI 的 BGE-M3）---
VERTEX_PROJECT=lab-teacher-xxxxxx        # 本 VM 所屬專案（用自家 Vertex）
VERTEX_LOCATION=us-central1
TEI_BASE=http://<shared-ip>:8081/v1      # 共用 lab-shared 的 BGE-M3
LITELLM_MASTER_KEY=sk-lab-master-xxxx

# --- graphrag / LightRAG（指向本機 LiteLLM）---
OPENAI_API_KEY=sk-lab-master-xxxx        # = LITELLM_MASTER_KEY
OPENAI_API_BASE=http://litellm:4000/v1   # 同 compose 網路內以服務名相連
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# --- Neo4j（共用 lab-shared，本 VM 專屬 db）---
NEO4J_URI=bolt://<shared-ip>:7687
NEO4J_USERNAME=teacher
NEO4J_PASSWORD=請填入
NEO4J_DATABASE=lab_teacher

# --- graphrag adapter ---
DIFY_EXTERNAL_KNOWLEDGE_API_KEY=lab-graphrag-secret
LIGHTRAG_WORKING_DIR=./rag_storage
ADAPTER_PORT=8000

# --- LINE 橋接（接 Dify app；課中填）---
LINE_CHANNEL_SECRET=FILL_IN_LINE_LAB
LINE_CHANNEL_ACCESS_TOKEN=FILL_IN_LINE_LAB
DIFY_API_BASE=http://localhost/v1
DIFY_APP_KEY=FILL_IN_AFTER_BUILDING_APP

# --- Caddy / HTTPS ---
LAB_DOMAIN=<ip-dashed>.sslip.io
