# 複製成 terraform.tfvars 後填值：cp terraform.tfvars.example terraform.tfvars
org_id             = "695375997648"          # tsg-cs-rock-org
billing_account    = "012F8F-1E0389-812C9E"
quota_project      = "basic-breaker-490002-a2" # 既有專案，當 provider quota project
folder_name        = "low-code-rag-lab"
region             = "asia-east1"
zone               = "asia-east1-b"

student_count      = 1                        # 彩排先 1（= shared + teacher + student1 共 3 專案），通過再改 8
ssh_user           = "lab"
ssh_pubkey_path    = "~/.ssh/id_ed25519.pub"
repo_url           = "https://github.com/osisdie/low-code-rag-lab.git"

vertex_location    = "us-central1"            # gemini-2.5-flash 區域
# 下面三個敏感值：apply 時用 -var 帶入（隨機產生），勿寫死在版控檔
litellm_master_key = ""                        # 隨機字串
hf_token           = ""                         # 貼上 HuggingFace token
neo4j_password     = ""                         # 設一組強密碼
graphrag_key       = "lab-graphrag-secret"
create_sa_key      = true
budget_amount      = 300
