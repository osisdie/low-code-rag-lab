# 複製成 .env 後填入你的值
# cp .env.example .env

# 複製成 .env 後填入你的值：cp .env.example .env
#
# 兩種模式：
#  (A) 公開 take-home 輕量模式：OpenAI + 檔案式圖譜（不填 NEO4J_*）
#  (B) 課堂 GCP 模式：LiteLLM(Vertex Gemini) + BGE-M3 + Neo4j（填 NEO4J_* 與下方 LiteLLM 值）

# --- LLM / Embedding（LightRAG 用來抽取實體關係 + 向量化）---
# 任一 OpenAI 相容 API 皆可（OpenAI / LiteLLM / Azure / 本地 vLLM）
# 模式 A（OpenAI）：
OPENAI_API_KEY=sk-請填入你的key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# 模式 B（課堂，改成以下：指向 lab-svc 的 LiteLLM）：
#   OPENAI_API_KEY=<你的 LiteLLM virtual key>
#   OPENAI_API_BASE=http://<lab-svc-ip>:4000/v1
#   LLM_MODEL=gemini-2.5-flash
#   EMBEDDING_MODEL=bge-m3
#   EMBEDDING_DIM=1024

# --- Neo4j 圖儲存（只在課堂模式 B 填；留空則用檔案式 NetworkX）---
# NEO4J_URI=bolt://<lab-svc-ip>:7687
# NEO4J_USERNAME=student1
# NEO4J_PASSWORD=請填入分配到的密碼
# NEO4J_DATABASE=lab_student_1

# --- Dify External Knowledge API 連線用的 Bearer 金鑰 ---
# Dify 端設定外掛知識庫時要填同一把（自己取，課堂用簡單字串即可）
DIFY_EXTERNAL_KNOWLEDGE_API_KEY=lab-graphrag-secret

# --- LightRAG 工作目錄（檔案式索引存這；Neo4j 模式下圖譜存 Neo4j）---
LIGHTRAG_WORKING_DIR=./rag_storage

# --- adapter 服務埠 ---
ADAPTER_PORT=8000
