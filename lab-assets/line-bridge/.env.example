# LINE ↔ Dify 橋接設定（複製成 .env）
# 從 LINE Developers Console 的 Messaging API channel 取得：
LINE_CHANNEL_SECRET=請填入_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=請填入_long_lived_access_token

# Dify：你的客服 app 的 API endpoint 與 API key（Dify app →「存取 API」）
DIFY_API_BASE=http://localhost/v1
DIFY_APP_KEY=app-請填入你的Dify_app_key
